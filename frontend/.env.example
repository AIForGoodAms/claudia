# Backend wiring (see src/services/config.ts). Copy to `.env.local` to override.
#
# Mock (default) — in-browser fake, no backend needed:
#   VITE_TRANSPORT=mock
#
# Real backend — local FastAPI from api-contract.md:
#   VITE_TRANSPORT=ws
#
# Transport selector: 'mock' | 'ws'
VITE_TRANSPORT=mock

# Backend bases (defaults match the contract's dev URLs; only needed if different)
VITE_BACKEND_HTTP_URL=http://127.0.0.1:8000
VITE_BACKEND_WS_URL=ws://127.0.0.1:8000
